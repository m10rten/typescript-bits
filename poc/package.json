{
  "name": "poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:package": "pnpm --filter @poc/my-utils build",
    "build:site": "pnpm --filter @poc/website generate",
    "build": "pnpm build:package && pnpm build:site",
    "install-utils": "pnpm --filter @poc/install-cli -- install-utils",
    "serve": "pnpm --filter @poc/website serve"
  }
}
