{
  "name": "typescript-bits",
  "version": "0.0.0",
  "description": "A collection of TypeScript utility primitives for Node.js",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "precommit": "pnpm format:check && pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "build": "zshy",
    "test": "tsx --test tests/*.test.ts"
  },
  "keywords": [],
  "author": "m10rten",
  "license": "MIT",
  "packageManager": "pnpm@11.1.2",
  "devDependencies": {
    "@types/node": "25.6.2",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "zshy": "0.7.2"
  },
  "files": [
    "dist"
  ],
  "zshy": {
    "exports": {
      ".": "./src/index.ts",
      "./result": "./src/result.ts",
      "./safe": "./src/safe.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./result": {
      "types": "./dist/result.d.cts",
      "import": "./dist/result.js",
      "require": "./dist/result.cjs"
    },
    "./safe": {
      "types": "./dist/safe.d.cts",
      "import": "./dist/safe.js",
      "require": "./dist/safe.cjs"
    }
  }
}
